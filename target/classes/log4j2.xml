<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{ISO8601} %-5level [%t] %c{1} - %msg p:[%X{resource.name}:%X{resource.namespace}] %n%throwable"/>
    </Console>
  </Appenders>
  <Loggers>
    <Logger name="io.example.operator" level="debug" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="io.javaoperatorsdk" level="info" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Root level="warn">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>